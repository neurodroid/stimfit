#!/usr/bin/env bash
set -euo pipefail

VERSION=@PACKAGE_VERSION@

# cowbuilder uses a base *directory* (COW base), not a .tgz
BASE_COW="${HOME}/pbuilder/sid-base.cow"

TOPDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEBDIR="${TOPDIR}/../deb"
RESULTDIR="${DEBDIR}/result"

# Persist package downloads across runs
APT_CACHE_DIR="${HOME}/pbuilder/aptcache"

# Optional: set this in your environment, e.g.
#   export DEBSIGN_KEYID=0xYOURKEYID
MAINT_EMAIL="christsc@gmx.de"

# ---------------------------------------------------------------------------
# Flags — pass any combination to force specific stages:
#   --force-dist    re-run "make dist" even if tarball is up-to-date
#   --force-source  rebuild the source package even if .dsc is up-to-date
#   --force-binary  rebuild the binary packages even if .debs are up-to-date
#   --force         force all three stages (full rebuild)
#   --source-only   skip binary build (signing still runs at the end)
# ---------------------------------------------------------------------------
FORCE_DIST=0
FORCE_SOURCE=0
FORCE_BINARY=0
SOURCE_ONLY=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force-dist)   FORCE_DIST=1 ;;
    --force-source) FORCE_SOURCE=1 ;;
    --force-binary) FORCE_BINARY=1 ;;
    --force)        FORCE_DIST=1; FORCE_SOURCE=1; FORCE_BINARY=1 ;;
    --source-only)  SOURCE_ONLY=1 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
  shift
done

# Find the primary key fingerprint whose sec record is followed by a uid
# matching the maintainer email.  The colon format emits records in this order:
#   sec … (primary key)
#   fpr … (primary key fingerprint)  ← field 10
#   grp …
#   uid … (one per identity)
# We capture the most-recent fpr after a sec record and emit it when we see a
# matching uid — this avoids accidentally picking up a subkey fingerprint, and
# uses the full fingerprint as recommended by debsign.
DEBSIGN_KEYID="$(
  gpg --list-secret-keys --with-colons --fingerprint 2>/dev/null \
  | awk -F: -v email="$MAINT_EMAIL" '
      $1=="sec"              { fpr="" }
      $1=="fpr" && fpr==""   { fpr=$10 }
      $1=="uid" && $10 ~ email && fpr != "" { print fpr; exit }
    '
)"

TARBALL="stimfit-${VERSION}.tar.gz"
# Debian packaging now lives in-tree under debian/ (not dist/debian).
DEBIAN_DIST_DIR="${TOPDIR}"

# ---------------------------------------------------------------------------
# Stage 1: make dist — skip if tarball already exists (use --force-dist to redo)
# ---------------------------------------------------------------------------

if [[ $FORCE_DIST -eq 1 ]] || [[ ! -f "${TARBALL}" ]]; then
  echo "==> Running make dist..."
  make dist
else
  echo "==> Tarball ${TARBALL} exists; skipping make dist (use --force-dist to regenerate)."
fi

# ---------------------------------------------------------------------------
# Stage 2: Build the source package — skip when .dsc is already newer
# than both the tarball and debian/control (use --force-source to redo)
# ---------------------------------------------------------------------------

mkdir -p "${RESULTDIR}"

EXISTING_DSC="$(ls -1t "${DEBDIR}"/stimfit_"${VERSION}"-*.dsc 2>/dev/null | head -n1 || true)"
EXISTING_CHANGES="$(ls -1t "${DEBDIR}"/*_source.changes 2>/dev/null | head -n1 || true)"

SKIP_SOURCE=0
if [[ $FORCE_SOURCE -eq 0 && -n "${EXISTING_DSC}" ]]; then
  # Skip if the existing .dsc is newer than both the tarball and debian/control
  if [[ "${EXISTING_DSC}" -nt "${TARBALL}" && "${EXISTING_DSC}" -nt "${DEBIAN_DIST_DIR}/control" ]]; then
    echo "==> Source package ${EXISTING_DSC} is up-to-date; skipping source build."
    echo "    (use --force-source to rebuild)"
    SKIP_SOURCE=1
    DSC="${EXISTING_DSC}"
    CHANGES="${EXISTING_CHANGES}"
    # Copy existing artifacts into RESULTDIR so signing always operates there.
    cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.dsc             "${RESULTDIR}/" 2>/dev/null || true
    cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*_source.changes  "${RESULTDIR}/" 2>/dev/null || true
    cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*_source.buildinfo "${RESULTDIR}/" 2>/dev/null || true
    cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.debian.tar.*    "${RESULTDIR}/" 2>/dev/null || true
    cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.orig.tar.*      "${RESULTDIR}/" 2>/dev/null || true
  fi
fi

if [[ $SKIP_SOURCE -eq 0 ]]; then
  echo "==> Building source package..."

  # Clean the staging area but keep the result/ subdirectory
  find "${DEBDIR}" -mindepth 1 -maxdepth 1 ! -name result -exec rm -rf {} +

  # Prepare orig tarball
  cp -v "${TARBALL}" "${DEBDIR}/"
  cp -v "${TARBALL}" "${DEBDIR}/stimfit_${VERSION}.orig.tar.gz"

  # Unpack + add debian/
  cd "${DEBDIR}"
  tar -xzf "stimfit_${VERSION}.orig.tar.gz"
  cd "stimfit-${VERSION}"

  cp -rv "${DEBIAN_DIST_DIR}" ./
  test -d debian

  # -------------------------------------------------------------------------
  # Build the source package inside the sid cowbuilder chroot (UNSIGNED).
  #
  # NOTE: dpkg-buildpackage -S only packages source files — it never compiles
  # anything and requires NO build-dependencies to be installed.  The previous
  # apt-get update + apt-get build-dep calls here were entirely unnecessary.
  # -------------------------------------------------------------------------

  sudo cowbuilder execute \
    --basepath "${BASE_COW}" \
    --aptcache "${APT_CACHE_DIR}" \
    --bindmounts "${DEBDIR}" \
    -- /bin/bash -lc "
      set -euo pipefail
      cd '${DEBDIR}/stimfit-${VERSION}'
      # Source-only build: no compilation, no build-deps needed.
      dpkg-buildpackage -S -sa -us -uc -d -nc
    "

  # cowbuilder execute ran as root; artifacts may be root-owned on host.
  sudo chown -R "$(id -u):$(id -g)" "${DEBDIR}" "${RESULTDIR}"

  # Find the newly created source .changes / .dsc (should be in ${DEBDIR})
  CHANGES="$(ls -1t "${DEBDIR}"/*_source.changes | head -n1)"
  DSC="$(ls -1t "${DEBDIR}"/*.dsc | head -n1)"

  echo "Source package: ${DSC}"
  echo "Source changes: ${CHANGES}"

  # Copy unsigned source artifacts into RESULTDIR
  cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.dsc             "${RESULTDIR}/" 2>/dev/null || true
  cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*_source.changes  "${RESULTDIR}/" 2>/dev/null || true
  cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*_source.buildinfo "${RESULTDIR}/" 2>/dev/null || true
  cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.debian.tar.*    "${RESULTDIR}/" 2>/dev/null || true
  cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.orig.tar.*      "${RESULTDIR}/" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Stage 3: Build binaries inside cowbuilder — skip when .debs are already
# newer than the .dsc (use --force-binary to redo)
# ---------------------------------------------------------------------------

if [[ $SOURCE_ONLY -eq 0 ]]; then
  EXISTING_DEB="$(ls -1t "${RESULTDIR}"/*.deb 2>/dev/null | head -n1 || true)"

  SKIP_BINARY=0
  if [[ $FORCE_BINARY -eq 0 && -n "${EXISTING_DEB}" ]]; then
    if [[ "${EXISTING_DEB}" -nt "${DSC}" ]]; then
      echo "==> Binary packages in ${RESULTDIR} are up-to-date; skipping binary build."
      echo "    (use --force-binary to rebuild)"
      SKIP_BINARY=1
    fi
  fi

  if [[ $SKIP_BINARY -eq 0 ]]; then
    echo "==> Building binary packages..."

    # Use all available cores.
    sudo cowbuilder build \
      --basepath "${BASE_COW}" \
      --buildresult "${RESULTDIR}" \
      --debbuildopts "-j$(nproc)" \
      "${DSC}"

    sudo chown -R "$(id -u):$(id -g)" "${RESULTDIR}"
  fi
else
  echo "==> --source-only requested; skipping binary build."
fi

# ---------------------------------------------------------------------------
# Stage 4: Sign all .changes files in deb/ and result/
# ---------------------------------------------------------------------------

if [[ -z "${DEBSIGN_KEYID}" ]]; then
  echo "ERROR: Could not find a GPG secret key for ${MAINT_EMAIL}" >&2
  exit 1
fi

echo "==> Signing all .changes files in ${DEBDIR} and ${RESULTDIR}..."

# Collect .changes from both directories (deduplicated by absolute path).
# RESULTDIR is a subdirectory of DEBDIR, so list them separately.
mapfile -t ALL_CHANGES < <(
  { ls -1 "${DEBDIR}"/*.changes 2>/dev/null || true
    ls -1 "${RESULTDIR}"/*.changes 2>/dev/null || true
  } | sort -u
)

if [[ ${#ALL_CHANGES[@]} -eq 0 ]]; then
  echo "ERROR: No .changes files found in ${DEBDIR} or ${RESULTDIR}" >&2
  exit 1
fi

for CHANGES_FILE in "${ALL_CHANGES[@]}"; do
  [[ -f "${CHANGES_FILE}" ]] || continue
  echo "==> Signing: ${CHANGES_FILE}"
  debsign -k"${DEBSIGN_KEYID}" "${CHANGES_FILE}"
  # Verify the signature was actually applied — debsign can exit 0 even on
  # certain failures, so we check explicitly.
  if ! gpg --batch --status-fd 1 --verify "${CHANGES_FILE}" 2>/dev/null \
       | grep -q '\[GNUPG:\] GOODSIG'; then
    echo "ERROR: Signature verification failed for ${CHANGES_FILE}" >&2
    echo "       Run 'gpg --verify ${CHANGES_FILE}' for details." >&2
    exit 1
  fi
  echo "    Signed and verified OK: $(basename "${CHANGES_FILE}")"
done

echo "==> All .changes files signed and verified OK."

# Update CHANGES to the most-recent source .changes in RESULTDIR for the upload hint.
CHANGES="$(ls -1t "${RESULTDIR}"/*_source.changes 2>/dev/null | head -n1 || echo "")"

echo "Done. Artifacts in: ${RESULTDIR}"
echo "Upload with: dput mentors $(basename "${CHANGES}")  (from ${RESULTDIR})"
