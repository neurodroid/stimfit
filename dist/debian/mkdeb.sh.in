#!/usr/bin/env bash
set -euo pipefail

VERSION=@PACKAGE_VERSION@

# cowbuilder uses a base *directory* (COW base), not a .tgz
BASE_COW="${HOME}/pbuilder/sid-base.cow"

TOPDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEBDIR="${TOPDIR}/../deb"
RESULTDIR="${DEBDIR}/result"

# Persist package downloads across runs
APT_CACHE_DIR="${HOME}/pbuilder/aptcache"

# Used only to auto-pick the signing key (fingerprint) from your local keyring
MAINT_EMAIL="christsc@gmx.de"

# Prefer signing as the invoking user (not root), so ~/.gnupg is used.
SIGN_USER="${SUDO_USER:-$USER}"

# ---------------------------------------------------------------------------
# Helper: pick a signing key fingerprint for MAINT_EMAIL (or fall back to first secret key)
# ---------------------------------------------------------------------------
pick_debsign_keyid() {
  local email="$1"

  # Try: secret key whose UID contains the email; take its fingerprint
  local key
  key="$(
    gpg --list-secret-keys --with-colons --fingerprint 2>/dev/null \
    | awk -F: -v email="$email" '
        $1=="uid" && $10 ~ email { found=1 }
        found && $1=="fpr" { print $10; exit }
      '
  )"
  if [[ -n "${key}" ]]; then
    printf '%s\n' "${key}"
    return 0
  fi

  # Fallback: first secret key fingerprint
  key="$(
    gpg --list-secret-keys --with-colons --fingerprint 2>/dev/null \
    | awk -F: '/^fpr:/ { print $10; exit }'
  )"
  if [[ -n "${key}" ]]; then
    printf '%s\n' "${key}"
    return 0
  fi

  return 1
}

make dist

mkdir -p "${DEBDIR}"
rm -rf "${DEBDIR:?}/"*
mkdir -p "${RESULTDIR}"

# Prepare orig tarball
cp -v "stimfit-${VERSION}.tar.gz" "${DEBDIR}/"
cp -v "stimfit-${VERSION}.tar.gz" "${DEBDIR}/stimfit_${VERSION}.orig.tar.gz"

# Unpack + add debian/
cd "${DEBDIR}"
tar -xzf "stimfit_${VERSION}.orig.tar.gz"
cd "stimfit-${VERSION}"

cp -rv "${TOPDIR}/../../dist/debian" ./
test -d debian

# ---------------------------------------------------------------------------
# Build the source package inside the sid cowbuilder chroot (UNSIGNED)
# ---------------------------------------------------------------------------

sudo cowbuilder execute \
  --basepath "${BASE_COW}" \
  --aptcache "${APT_CACHE_DIR}" \
  --bindmounts "${DEBDIR}" \
  -- /bin/bash -lc "
    set -euo pipefail
    apt-get update
    apt-get -y build-dep '${DEBDIR}/stimfit-${VERSION}'
    cd '${DEBDIR}/stimfit-${VERSION}'
    # Build source package WITHOUT signing; we'll sign once on the host at the very end.
    dpkg-buildpackage -S -sa -us -uc
  "

# cowbuilder execute ran as root inside chroot; artifacts may be root-owned on host.
sudo chown -R "$(id -u):$(id -g)" "${DEBDIR}"

# Find the newly created source artifacts (in ${DEBDIR})
CHANGES_SRC="$(ls -1t "${DEBDIR}"/*_source.changes | head -n1)"
DSC_SRC="$(ls -1t "${DEBDIR}"/*.dsc | head -n1)"

echo "Source package: ${DSC_SRC}"
echo "Source changes: ${CHANGES_SRC}"

# ---------------------------------------------------------------------------
# Build binaries inside cowbuilder (installs Build-Depends as needed)
# ---------------------------------------------------------------------------

sudo cowbuilder build \
  --basepath "${BASE_COW}" \
  --buildresult "${RESULTDIR}" \
  "${DSC_SRC}"

# Make sure build results are user-owned
sudo chown -R "$(id -u):$(id -g)" "${RESULTDIR}"

# ---------------------------------------------------------------------------
# Prepare upload set in RESULTDIR and SIGN ONLY ONCE (the exact file to be uploaded)
# ---------------------------------------------------------------------------

# Copy the source upload set next to the binaries for convenience
cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.dsc "${RESULTDIR}/"
cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*_source.changes "${RESULTDIR}/"
cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.debian.tar.* "${RESULTDIR}/"
cp -v "${DEBDIR}/"stimfit_"${VERSION}"-*.orig.tar.* "${RESULTDIR}/"

CHANGES_UP="${RESULTDIR}/$(basename "${CHANGES_SRC}")"
DSC_UP="${RESULTDIR}/$(basename "${DSC_SRC}")"

# Pick signing key (fingerprint) from the host user's keyring
DEBSIGN_KEYID="$(sudo -u "${SIGN_USER}" bash -lc "$(declare -f pick_debsign_keyid); pick_debsign_keyid '${MAINT_EMAIL}'" )" || {
  cat >&2 <<EOF
ERROR: No suitable GPG secret key found for signing.
- Ensure your secret key is available in ${SIGN_USER}'s keyring (~/.gnupg).
- Or adjust MAINT_EMAIL (${MAINT_EMAIL}) to match your UID/email.
EOF
  exit 1
}

# Sign THE upload copy (in RESULTDIR), once.
sudo -u "${SIGN_USER}" debsign -k"${DEBSIGN_KEYID}" "${CHANGES_UP}"

# Sanity check: ensure the upload .changes is clearsigned
grep -q "BEGIN PGP SIGNATURE" "${CHANGES_UP}" || {
  echo "ERROR: ${CHANGES_UP} does not contain a PGP signature block after debsign." >&2
  exit 1
}

# Optional: verify signatures (useful while iterating/debugging)
sudo -u "${SIGN_USER}" gpg --verify "${CHANGES_UP}"
sudo -u "${SIGN_USER}" gpg --verify "${DSC_UP}"

echo "Done. Artifacts in: ${RESULTDIR}"
echo "Upload with: dput mentors $(basename "${CHANGES_UP}")"
